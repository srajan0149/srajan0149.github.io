{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["DOM", "ES2020"],

    "rootDir": "./src",
    "outDir": "./build",

    "strict": true,

    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "sourceMap": true,
    "noEmitOnError": true,

    "isolatedModules": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
